{% extends 'base.html.twig' %}

{% block title %}Actualité #{{ newsId }} - VeGlobs{% endblock %}
{% block meta_description %}Détail de l'actualité transport #{{ newsId }} sur VeGlobs Paris — perturbations, travaux et infos trafic en temps réel.{% endblock %}
{% block og_title %}Actualité #{{ newsId }} - VeGlobs{% endblock %}
{% block og_description %}Consultez les détails de cette actualité transport sur VeGlobs Paris.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/navbar.css') }}">
    <link rel="stylesheet" href="{{ asset('css/news-detail.css') }}">
{% endblock %}

{% block body %}

{# ══ NAVBAR ══ #}
<nav class="vg-navbar" id="vg-navbar">
  <div class="vg-navbar__rainbow"></div>
  <div class="vg-navbar__top">

    <a href="{{ path('app_home') }}" class="vg-navbar__logo">
      <span style="font-size:17px;font-weight:800;color:#0891b2;letter-spacing:-.5px;">Ve<span style="color:#1a1d2e;">Globs</span></span>
    </a>

    <div class="vg-navbar__links" id="vg-links">
      <a href="{{ path('app_home') }}" class="vg-navbar__link">Accueil</a>
      <a href="{{ path('app_news') }}" class="vg-navbar__link vg-navbar__link--active">News</a>
      <a href="{{ path('app_journey_planner') }}" class="vg-navbar__link">Itinéraire</a>
      <a href="{{ path('transport_map') }}" class="vg-navbar__link">Transport</a>
      <a href="{{ path('app_velib') }}" class="vg-navbar__link">Vélib</a>
    </div>

    <div class="vg-navbar__right">
      <div class="vg-navbar__social">
        <a href="#" class="vg-navbar__social-btn"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="vg-navbar__social-btn"><i class="fab fa-twitter"></i></a>
        <a href="#" class="vg-navbar__social-btn"><i class="fab fa-youtube"></i></a>
      </div>
      <button class="vg-navbar__search-btn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      {% if app.user %}
        <div class="vg-navbar__avatar">{{ app.user.firstName|first|upper|default('?') }}{{ app.user.lastName|first|upper|default('') }}</div>
        <a href="{{ path('app_logout') }}" class="vg-navbar__account-btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>Déconnexion</span>
        </a>
      {% else %}
        <a href="{{ path('app_login') }}" class="vg-navbar__account-btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <span>Mon Compte</span>
        </a>
      {% endif %}
      <button class="vg-navbar__burger" id="vg-burger"><span></span><span></span><span></span></button>
    </div>
  </div>

  {# Filtres transport #}
  <div class="vg-navbar__filters">
    <button class="vg-filter-btn" data-filter="all" onclick="window.location.href='{{ path('app_news') }}'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="14" y="3" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="3" y="14" width="7" height="7" rx="1.5" fill="currentColor"/><rect x="14" y="14" width="7" height="7" rx="1.5" fill="currentColor"/></svg>
      Tout
    </button>
    <button class="vg-filter-btn" data-filter="metro" onclick="window.location.href='{{ path('app_news') }}?network=metro'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="5" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="18" r="2" fill="currentColor"/><circle cx="15" cy="18" r="2" fill="currentColor"/></svg>
      Métro
      <span class="lb lm4">4</span><span class="lb lm13">13</span><span class="lb lm1">1</span>
    </button>
    <button class="vg-filter-btn" data-filter="rer" onclick="window.location.href='{{ path('app_news') }}?network=rer'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="13" rx="2" stroke="currentColor" stroke-width="2"/><circle cx="8" cy="19" r="2" fill="currentColor"/><circle cx="16" cy="19" r="2" fill="currentColor"/></svg>
      RER
      <span class="lb rer lrera">A</span><span class="lb rer lrerb">B</span><span class="lb rer lrerc">C</span>
    </button>
    <button class="vg-filter-btn" data-filter="tram" onclick="window.location.href='{{ path('app_news') }}?network=tram'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="11" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 19h18M7 19v-3M17 19v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Tram
      <span class="lb tram lt3a">T3a</span><span class="lb tram lt2">T2</span>
    </button>
    <button class="vg-filter-btn" data-filter="bus" onclick="window.location.href='{{ path('app_news') }}?network=bus'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="13" rx="2" stroke="currentColor" stroke-width="2"/><circle cx="7.5" cy="19" r="1.5" fill="currentColor"/><circle cx="16.5" cy="19" r="1.5" fill="currentColor"/><path d="M3 9h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Bus
      <span class="lb lbus">N</span>
    </button>
    <button class="vg-filter-btn" data-filter="transilien" onclick="window.location.href='{{ path('app_news') }}?network=transilien'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M4 17L12 3l8 14H4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
      Transilien
      <span class="lb tram ltrans">H</span>
    </button>
  </div>
</nav>
<div class="vg-navbar__overlay" id="vg-overlay"></div>

{# ══ PAGE DÉTAIL ══ #}
<div class="news-detail-page" style="padding-top:120px;">

    <nav style="display:flex;align-items:center;gap:6px;font-size:12px;color:#9ca3af;margin-bottom:16px;">
        <a href="{{ path('app_home') }}" style="color:#6b7280;text-decoration:none;">Accueil</a>
        <span style="color:#d1d5db;">›</span>
        <a href="{{ path('app_news') }}" style="color:#6b7280;text-decoration:none;">Actualités</a>
        <span style="color:#d1d5db;">›</span>
        <a href="{{ path('app_follow') }}" class="vg-navbar__link">Mes lignes</a>
        <span style="color:#d1d5db;">›</span>
        <a href="{{ path('app_follow') }}" class="vg-navbar__link">Mes lignes</a>
        <span>Détail</span>
    </nav>

    <a href="{{ path('app_news') }}" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#6b7280;text-decoration:none;margin-bottom:20px;padding:6px 12px;border-radius:10px;border:1px solid #e5e7eb;background:#fff;transition:all .15s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M19 12H5M12 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Retour aux actualités
    </a>

    <div
        id="news-detail"
        data-news-id="{{ newsId }}"
        data-is-authenticated="{{ app.user ? 'true' : 'false' }}"
        data-is-admin="{{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }}"
        data-login-url="{{ path('app_login') }}"
    >
        <div class="news-detail-loading">
            <div class="news-detail-loading__spinner"></div>
            <p>Chargement de l'actualité…</p>
        </div>
    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function(){
      var burger=document.getElementById('vg-burger');
      var overlay=document.getElementById('vg-overlay');
      var navbar=document.getElementById('vg-navbar');
      if(burger){burger.addEventListener('click',function(){navbar.classList.toggle('vg-navbar--open');overlay.classList.toggle('vg-navbar__overlay--visible');});}
      if(overlay){overlay.addEventListener('click',function(){navbar.classList.remove('vg-navbar--open');overlay.classList.remove('vg-navbar__overlay--visible');});}
    })();
    </script>
    <script src="{{ asset('js/news-detail.js') }}"></script>
{% endblock %}
