{% extends 'base.html.twig' %}

{% block title %}{{ news.title }} - VeGlobs{% endblock %}
{% block meta_description %}{{ news.content|striptags|slice(0, 150) }}{% endblock %}
{% block og_title %}{{ news.title }} - VeGlobs{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <a href="{{ path('app_news') }}" class="btn btn-outline-secondary btn-sm mb-4">
                <i class="bi bi-arrow-left me-1"></i>Retour aux actualités
            </a>

            {# ── Carte news ── #}
            {% if news.type == 'perturbation' %}{% set color = 'danger' %}
            {% elseif news.type == 'travaux' %}{% set color = 'warning' %}
            {% else %}{% set color = 'info' %}{% endif %}

            <div class="card shadow-sm border-top border-{{ color }} border-3 mb-4">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-{{ color }} text-dark">{{ news.type|capitalize }}</span>
                        <span class="badge bg-secondary">{{ news.network|upper }}</span>
                        {% if news.line %}<span class="badge bg-dark">{{ news.line }}</span>{% endif %}
                        <span class="badge bg-{{ news.source == 'community' ? 'success' : 'light text-dark border' }}">
                            {{ news.source == 'official' ? 'Officielle' : 'Communauté' }}
                        </span>
                    </div>
                    <h1 class="h4">{{ news.title }}</h1>
                    <div class="text-muted small mb-3">
                        <i class="bi bi-clock me-1"></i>{{ news.publishedAt|date('d/m/Y à H:i') }}
                        · <i class="bi bi-eye me-1"></i>{{ news.views }} vue{{ news.views > 1 ? 's' : '' }}
                        {% if news.author %}
                            · <i class="bi bi-person me-1"></i>{{ news.author.firstName|default('Admin') }}
                        {% endif %}
                    </div>
                    <div class="border-top pt-3">
                        {{ news.content|nl2br }}
                    </div>
                </div>
            </div>

            {# ── Signalement ── #}
            {% if app.user %}
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning bg-opacity-25">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Signaler un incident</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('app_news_show', {id: news.id}) }}">
                        <input type="hidden" name="report" value="1">
                        <input type="hidden" name="network" value="{{ news.network }}">
                        <input type="hidden" name="line" value="{{ news.line }}">
                        <div class="mb-3">
                            <label class="form-label">Type d'incident</label>
                            <select name="type" class="form-select form-select-sm">
                                <option value="perturbation">Perturbation</option>
                                <option value="incident">Incident</option>
                                <option value="travaux">Travaux</option>
                                <option value="info">Information</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="content" class="form-control" rows="3" placeholder="Décrivez l'incident..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-warning btn-sm">
                            <i class="bi bi-send me-1"></i>Envoyer le signalement
                        </button>
                    </form>
                </div>
            </div>
            {% endif %}

            {# ── Commentaires ── #}
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-chat me-2"></i>Commentaires ({{ news.comments|length }})</h5>
                </div>
                <div class="card-body">
                    {% if news.comments is empty %}
                        <p class="text-muted small">Aucun commentaire pour l'instant.</p>
                    {% else %}
                        {% for comment in news.comments %}
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong class="small">{{ comment.author.firstName|default('Utilisateur') }}</strong>
                                    <small class="text-muted">{{ comment.createdAt|date('d/m/Y H:i') }}</small>
                                </div>
                                <p class="mb-0 small mt-1">{{ comment.content }}</p>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <form method="POST" action="{{ path('app_comment_delete', {id: comment.id}) }}" class="mt-1">
                                        <button type="submit" class="btn btn-link btn-sm text-danger p-0" onclick="return confirm('Supprimer ?')">
                                            <i class="bi bi-trash"></i> Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}

                    {% if app.user %}
                        <form method="POST" action="{{ path('app_news_show', {id: news.id}) }}" class="mt-3">
                            <div class="mb-2">
                                <label class="form-label small fw-semibold">Votre commentaire</label>
                                <textarea name="content" class="form-control form-control-sm" rows="3" placeholder="Votre commentaire..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-dark btn-sm">
                                <i class="bi bi-send me-1"></i>Commenter
                            </button>
                        </form>
                    {% else %}
                        <div class="alert alert-light border mt-3 small">
                            <a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un commentaire.
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Actions admin ── #}
            {% if is_granted('ROLE_ADMIN') %}
                <div class="d-flex gap-2 mb-4">
                    <a href="{{ path('app_admin_news_edit', {id: news.id}) }}" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </a>
                    <form method="POST" action="{{ path('app_admin_news_delete', {id: news.id}) }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Supprimer ?')">
                            <i class="bi bi-trash me-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
