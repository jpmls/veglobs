{% extends 'base.html.twig' %}

{% block title %}Actualités Transport - VeGlobs{% endblock %}
{% block meta_description %}Toutes les actualités transport parisien — perturbations Métro, RER, Bus, Tram.{% endblock %}

{% block body %}
<div class="container">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0"><i class="bi bi-newspaper me-2"></i>Actualités Transport</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_news_create') }}" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Créer
            </a>
        {% endif %}
    </div>

    {# ── Filtres ── #}
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="GET" action="{{ path('app_news') }}" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Rechercher</label>
                    <input type="text" name="q" value="{{ filters.q }}" class="form-control form-control-sm" placeholder="Mot-clé...">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Réseau</label>
                    <select name="network" class="form-select form-select-sm">
                        <option value="">Tous</option>
                        <option value="metro" {% if filters.network == 'metro' %}selected{% endif %}>Métro</option>
                        <option value="rer"   {% if filters.network == 'rer' %}selected{% endif %}>RER</option>
                        <option value="bus"   {% if filters.network == 'bus' %}selected{% endif %}>Bus</option>
                        <option value="tram"  {% if filters.network == 'tram' %}selected{% endif %}>Tram</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Type</label>
                    <select name="type" class="form-select form-select-sm">
                        <option value="">Tous</option>
                        <option value="perturbation" {% if filters.type == 'perturbation' %}selected{% endif %}>Perturbation</option>
                        <option value="travaux"      {% if filters.type == 'travaux' %}selected{% endif %}>Travaux</option>
                        <option value="incident"     {% if filters.type == 'incident' %}selected{% endif %}>Incident</option>
                        <option value="info"         {% if filters.type == 'info' %}selected{% endif %}>Info</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Source</label>
                    <select name="source" class="form-select form-select-sm">
                        <option value="">Toutes</option>
                        <option value="official"  {% if filters.source == 'official' %}selected{% endif %}>Officielle</option>
                        <option value="community" {% if filters.source == 'community' %}selected{% endif %}>Communauté</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-sm w-100">
                        <i class="bi bi-search me-1"></i>Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# ── Liste news ── #}
    {% if news is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Aucune actualité pour ces filtres.
        </div>
    {% else %}
        <div class="row g-3">
            {% for item in news %}
                {% if item.type == 'perturbation' %}{% set color = 'danger' %}
                {% elseif item.type == 'travaux' %}{% set color = 'warning' %}
                {% elseif item.type == 'incident' %}{% set color = 'warning' %}
                {% else %}{% set color = 'info' %}{% endif %}

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-top border-{{ color }} border-3">
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                <span class="badge bg-{{ color }} text-dark">{{ item.type|capitalize }}</span>
                                <span class="badge bg-secondary">{{ item.network|upper }}</span>
                                {% if item.line %}<span class="badge bg-dark">{{ item.line }}</span>{% endif %}
                                <span class="badge bg-{{ item.source == 'community' ? 'success' : 'light text-dark border' }}">
                                    {{ item.source == 'official' ? 'Officielle' : 'Communauté' }}
                                </span>
                            </div>
                            <p class="card-text small">
                                {{ item.content|striptags|slice(0, 120) }}{% if item.content|length > 120 %}…{% endif %}
                            </p>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                {{ item.publishedAt|date('d/m/Y') }} · {{ item.views }} vue{{ item.views > 1 ? 's' : '' }}
                            </small>
                            <a href="{{ path('app_news_show', {id: item.id}) }}" class="btn btn-outline-dark btn-sm">
                                Voir →
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# ── Pagination ── #}
        {% if pages > 1 %}
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    {% if page > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_news', filters|merge({page: page - 1})) }}">‹ Préc</a>
                        </li>
                    {% endif %}
                    {% for p in max(1, page-2)..min(pages, page+2) %}
                        <li class="page-item {% if p == page %}active{% endif %}">
                            <a class="page-link" href="{{ path('app_news', filters|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    {% if page < pages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_news', filters|merge({page: page + 1})) }}">Suiv ›</a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}
    {% endif %}

</div>
{% endblock %}
