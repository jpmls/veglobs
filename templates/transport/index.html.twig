{% extends 'base.html.twig' %}

{% block title %}Transport - VeGlobs{% endblock %}

{% block body %}
<div class="container py-5">

    <h1 class="mb-4">Transport</h1>
    <p class="mb-5 text-muted">
        Accède rapidement aux informations de transport en temps réel.
    </p>

    <div class="row g-4">

        <div class="col-md-4">
            <a href="{{ path('app_news') }}" class="card transport-card text-decoration-none">
                <div class="card-body text-center">
                    <h4>📰 Actualités</h4>
                    <p>Voir les perturbations et infos transports</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="{{ path('app_journey') }}" class="card transport-card text-decoration-none">
                <div class="card-body text-center">
                    <h4>🗺️ Itinéraire</h4>
                    <p>Calculer un trajet avec la carte</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="#" class="card transport-card text-decoration-none">
                <div class="card-body text-center">
                    <h4>🚇 Lignes</h4>
                    <p>Consulter les lignes de transport</p>
                </div>
            </a>
        </div>

    </div>

</div>
{% endblock %}