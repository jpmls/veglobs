{% extends 'base.html.twig' %}

{% block title %}Transport - VeGlobs{% endblock %}

{% block body %}
<div class="container">
    <h1 class="h3 mb-1"><i class="bi bi-train-front me-2"></i>Transport</h1>
    <p class="text-muted mb-4">Accédez rapidement aux informations de transport.</p>

    <div class="row g-4">
        <div class="col-md-4">
            <a href="{{ path('app_news') }}" class="card text-decoration-none h-100 shadow-sm">
                <div class="card-body text-center py-4">
                    <i class="bi bi-newspaper fs-1 text-danger mb-3 d-block"></i>
                    <h5>Actualités</h5>
                    <p class="text-muted small">Perturbations et infos transports</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('app_velib') }}" class="card text-decoration-none h-100 shadow-sm">
                <div class="card-body text-center py-4">
                    <i class="bi bi-bicycle fs-1 text-success mb-3 d-block"></i>
                    <h5>Vélib</h5>
                    <p class="text-muted small">Carte des stations Vélib</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('app_follow') }}" class="card text-decoration-none h-100 shadow-sm">
                <div class="card-body text-center py-4">
                    <i class="bi bi-star fs-1 text-warning mb-3 d-block"></i>
                    <h5>Mes lignes</h5>
                    <p class="text-muted small">Suivre vos lignes favorites</p>
                </div>
            </a>
        </div>
    </div>
</div>
{% endblock %}
