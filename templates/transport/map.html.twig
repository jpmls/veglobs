{% extends 'base.html.twig' %}

{% block body %}
<div class="app">

    <h1>VeGlobs – Itinéraire</h1>

    <div class="controls">
        <input type="text" id="start-input" placeholder="Point de départ">
        <input type="text" id="end-input" placeholder="Destination">
    </div>

    <div id="map"></div>

</div>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

<style>
body {
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    margin: 0;
}

.app {
    max-width: 900px;
    margin: auto;
    padding: 20px;
}

h1 {
    margin-bottom: 15px;
}

.controls {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
}

input {
    flex: 1;
    padding: 12px;
    border-radius: 10px;
    border: 1px solid #ddd;
    outline: none;
    font-size: 14px;
}

input:focus {
    border-color: #007bff;
}

#map {
    height: 500px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.9.0/proj4.js"></script>
<script src="{{ asset('js/map.js') }}"></script>
{% endblock %}