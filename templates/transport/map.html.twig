{% extends 'base.html.twig' %}

{% block body %}
<div class="page-transport">
    <div class="transport-header">
        <h1>VeGlobs – Itinéraire</h1>
        <p>Choisissez un départ et une destination.</p>
    </div>

    <div class="transport-form">
        <input type="text" id="start-input" placeholder="Point de départ" readonly>
        <input type="text" id="end-input" placeholder="Destination" readonly>
        <button type="button" id="reset-btn">Réinitialiser</button>
    </div>

    <div class="map-wrapper">
        <div id="map"></div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css">

    <style>
        body {
            margin: 0;
            background: #f3f4f6;
            font-family: Arial, sans-serif;
            color: #1f2937;
        }

        .page-transport {
            max-width: 1100px;
            margin: 0 auto;
            padding: 24px 16px 32px;
        }

        .transport-header {
            margin-bottom: 20px;
        }

        .transport-header h1 {
            margin: 0 0 6px;
            font-size: 2rem;
            font-weight: 700;
            color: #111827;
        }

        .transport-header p {
            margin: 0;
            color: #6b7280;
            font-size: 15px;
        }

        .transport-form {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .transport-form input {
            flex: 1;
            min-width: 240px;
            height: 46px;
            padding: 0 14px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            background: #ffffff;
            font-size: 15px;
            color: #111827;
            box-sizing: border-box;
        }

        .transport-form input::placeholder {
            color: #9ca3af;
        }

        .transport-form button {
            height: 46px;
            padding: 0 18px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            background: #ffffff;
            color: #111827;
            font-size: 14px;
            cursor: pointer;
        }

        .transport-form button:hover {
            background: #f9fafb;
        }

        .map-wrapper {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            overflow: hidden;
        }

        #map {
            width: 100%;
            height: 600px;
        }

        .leaflet-popup-content-wrapper {
            border-radius: 10px;
        }

        .leaflet-popup-content {
            font-size: 14px;
            line-height: 1.4;
        }

        @media (max-width: 768px) {
            .page-transport {
                padding: 16px 10px 24px;
            }

            .transport-header h1 {
                font-size: 1.6rem;
            }

            #map {
                height: 500px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
    <script src="{{ asset('js/map.js') }}"></script>
{% endblock %}