{% extends 'base.html.twig' %}

{% block title %}Actualités Transport - VeGlobs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/news.css') }}">
{% endblock %}

{% block body %}
<div
    class="news-page"
    data-is-admin="{{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }}"
    data-is-authenticated="{{ app.user ? 'true' : 'false' }}"
    data-login-url="{{ path('app_login') }}"
>
    <div class="news-topbar">
        <div class="news-title-block">
            <h1>Actualités Transport</h1>
            <p>Les dernières infos du réseau.</p>
        </div>

        <div class="news-filters">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin') }}" class="news-admin-btn">Dashboard admin</a>
            {% endif %}

            <input
                type="text"
                id="searchInput"
                class="news-search"
                placeholder="Rechercher..."
            >

            <select id="lineFilter" class="news-select">
                <option value="">Toutes les lignes</option>
            </select>

            <select id="typeFilter" class="news-select">
                <option value="">Tous types</option>
                <option value="official">Official</option>
                <option value="community">Community</option>
            </select>
        </div>
    </div>

    {% if is_granted('ROLE_ADMIN') %}
        <div style="margin-bottom: 20px;">
            <button id="create-news-btn" class="news-admin-btn">Créer une actualité</button>
        </div>
    {% endif %}

    <div id="news-list" class="news-list">
        <div class="news-card">Chargement...</div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/news.js') }}"></script>
{% endblock %}