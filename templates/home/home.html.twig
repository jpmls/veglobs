{% extends 'base.html.twig' %}

{% block title %}Accueil - VeGlobs sur Paris{% endblock %}

{% block body %}
<header class="header" data-header>

  <div class="overlay" data-overlay></div>

  <div class="header-top">
    <div class="container">

      <div class="wrapper"></div>

      <a href="/" class="logo">
        <img src="/images/ratp.png" alt="RATP logo">
      </a>

      <div class="header-btn-group">
        <button class="search-btn" aria-label="Search">
          <ion-icon name="search"></ion-icon>
        </button>

        <button class="nav-open-btn" aria-label="Open Menu" data-nav-open-btn>
          <ion-icon name="menu-outline"></ion-icon>
        </button>
      </div>

    </div>
  </div>

  <div class="header-bottom">
    <div class="container">

      <ul class="social-list">
        <li>
          <a href="#" class="social-link">
            <i class="fab fa-facebook-f"></i>
          </a>
        </li>

        <li>
          <a href="#" class="social-link">
            <ion-icon name="logo-twitter"></ion-icon>
          </a>
        </li>

        <li>
          <a href="#" class="social-link">
            <ion-icon name="logo-youtube"></ion-icon>
          </a>
        </li>
      </ul>

      <nav class="navbar" data-navbar>

        <div class="navbar-top">
          <a href="/" class="logo">
            <img src="/images/ratp.png" alt="RATP logo">
          </a>

          <button class="nav-close-btn" aria-label="Close Menu" data-nav-close-btn>
            <ion-icon name="close-outline"></ion-icon>
          </button>
        </div>

        <ul class="navbar-list">
          <li>
            <a href="/" class="navbar-link" data-nav-link>Accueil</a>
          </li>

          <li>
            <a href="/journey" class="navbar-link" data-nav-link>Itinéraire</a>
          </li>

          <li>
            <a href="/news" class="navbar-link" data-nav-link>News</a>
          </li>

          <li>
            <a href="/transport" class="navbar-link" data-nav-link>Transport</a>
          </li>

          <li>
            <a href="/velib" class="navbar-link" data-nav-link>Vélib</a>
          </li>
        </ul>

      </nav>

      <a href="/login" class="btn btn-primary">Mon compte</a>

    </div>
  </div>

</header>

<main>
  <article>
    <section class="hero" id="home">
      <div class="container">

        <h2 class="h1 hero-title">RATP</h2>

        <p class="hero-text">
          Ac mi duis mollis. Sapiente? Scelerisque quae, penatibus? Suscipit class corporis nostra rem quos
          voluptatibus habitant? Fames, vivamus minim nemo enim, gravida lobortis quasi, eum.
        </p>

        <div class="btn-group">
          <button class="btn btn-primary">En savoir Plus</button>
          <button class="btn btn-secondary">Cliquez Içi</button>
        </div>

      </div>
    </section>

    <section class="tour-search">
      <div class="container">

        <form action="" class="tour-search-form">

          <div class="input-wrapper">
            <label for="destination" class="input-label">Itinéarire</label>
            <input
              type="text"
              name="destination"
              id="destination"
              required
              placeholder="Entrez la Destination"
              class="input-field"
            >
          </div>

          <div class="input-wrapper">
            <label for="people" class="input-label">Numéro de Ligne</label>
            <input
              type="number"
              name="people"
              id="people"
              required
              placeholder="No.of People"
              class="input-field"
            >
          </div>

          <div class="input-wrapper">
            <label for="checkin" class="input-label">Entrez la date</label>
            <input
              type="date"
              name="checkin"
              id="checkin"
              required
              class="input-field"
            >
          </div>

          <div class="input-wrapper">
            <label for="checkout" class="input-label">Entrez la date</label>
            <input
              type="date"
              name="checkout"
              id="checkout"
              required
              class="input-field"
            >
          </div>

          <button type="submit" class="btn btn-secondary">Recherche</button>
        </form>

      </div>
    </section>
  </article>
</main>

<a href="#top" class="go-top" data-go-top>
  <ion-icon name="chevron-up-outline"></ion-icon>
</a>
{% endblock %}