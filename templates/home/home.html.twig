{% extends 'base.html.twig' %}

{% block title %}VeGlobs sur Paris — Infos trafic en temps réel{% endblock %}

{% block body %}

{# ── Hero ── #}
<div class="bg-dark text-white py-5">
    <div class="container text-center py-4">
        <h1 class="display-5 fw-bold mb-3">🚇 VeGlobs sur Paris</h1>
        <p class="lead mb-4">Suivez les perturbations, travaux et actualités des transports parisiens en temps réel.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="{{ path('app_news') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-newspaper me-2"></i>Voir les actualités
            </a>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-person-plus me-2"></i>S'inscrire
                </a>
            {% endif %}
        </div>
    </div>
</div>

{# ── Filtres rapides ── #}
<div class="container my-5">
    <h2 class="h4 mb-4 text-center">Filtrer par réseau</h2>
    <div class="row g-3 justify-content-center">
        {% for network, icon in {metro: 'train-front', rer: 'train-front-fill', bus: 'bus-front', tram: 'tram-front'} %}
            <div class="col-6 col-md-3">
                <a href="{{ path('app_news', {network: network}) }}" class="card text-center text-decoration-none h-100 shadow-sm">
                    <div class="card-body py-4">
                        <i class="bi bi-{{ icon }} fs-2 text-dark mb-2 d-block"></i>
                        <span class="fw-semibold text-capitalize">{{ network|upper }}</span>
                    </div>
                </a>
            </div>
        {% endfor %}
    </div>
</div>

{# ── Dernières actualités ── #}
{% if latestNews is defined and latestNews is not empty %}
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Dernières actualités</h2>
        <a href="{{ path('app_news') }}" class="btn btn-outline-dark btn-sm">Tout voir →</a>
    </div>
    <div class="row g-3">
        {% for item in latestNews %}
            {% if item.type == 'perturbation' %}{% set color = 'danger' %}
            {% elseif item.type == 'travaux' %}{% set color = 'warning' %}
            {% else %}{% set color = 'info' %}{% endif %}
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-top border-{{ color }} border-3">
                    <div class="card-body">
                        <div class="d-flex gap-1 mb-2">
                            <span class="badge bg-{{ color }} text-dark">{{ item.type|capitalize }}</span>
                            <span class="badge bg-secondary">{{ item.network|upper }}</span>
                        </div>
                        <p class="card-text small">{{ item.content|striptags|slice(0, 100) }}…</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between">
                        <small class="text-muted">{{ item.publishedAt|date('d/m/Y') }}</small>
                        <a href="{{ path('app_news_show', {id: item.id}) }}" class="btn btn-outline-dark btn-sm">Voir →</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% endblock %}
