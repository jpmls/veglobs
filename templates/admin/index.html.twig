{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - VeGlobs{% endblock %}

{% block body %}
<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">🛠 Dashboard Admin</h1>
            <p class="text-muted small mb-0">Bienvenue {{ app.user.email }}</p>
        </div>
        <a href="{{ path('app_news') }}" class="btn btn-outline-secondary btn-sm">← Retour au site</a>
    </div>

    {# ── Stats ── #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-top border-primary border-3 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase">Actualités</div>
                    <div class="fs-2 fw-bold">{{ totalNews }}</div>
                    <span class="badge bg-success">+{{ newsToday }} aujourd'hui</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-top border-success border-3 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase">Utilisateurs</div>
                    <div class="fs-2 fw-bold">{{ totalUsers }}</div>
                    <small class="text-muted">+{{ newUsers }} aujourd'hui</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-top border-warning border-3 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase">Commentaires</div>
                    <div class="fs-2 fw-bold">{{ totalComments }}</div>
                    <small class="text-muted">+{{ commentsToday }} aujourd'hui</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-top border-danger border-3 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small fw-semibold text-uppercase">Signalements</div>
                    <div class="fs-2 fw-bold">{{ communityNews|length }}</div>
                    <small class="text-muted">communautaires</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">

        {# ── Répartition par type ── #}
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold">Répartition par type</div>
                <div class="card-body">
                    {% set maxCount = 1 %}
                    {% for item in newsByType %}
                        {% if item.count > maxCount %}{% set maxCount = item.count %}{% endif %}
                    {% endfor %}
                    {% set colors = {'perturbation':'danger','travaux':'warning','info':'info','incident':'warning'} %}
                    {% for item in newsByType %}
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-capitalize small fw-semibold" style="min-width:100px;">{{ item.type }}</span>
                            <div class="progress flex-grow-1" style="height:8px;">
                                <div class="progress-bar bg-{{ colors[item.type]|default('secondary') }}"
                                     style="width:{{ (item.count / maxCount * 100)|round }}%"></div>
                            </div>
                            <small class="text-muted">{{ item.count }}</small>
                        </div>
                    {% endfor %}

                    <div class="mt-3 fw-semibold small">Activité — 7 derniers jours</div>
                    <div class="d-flex align-items-end gap-1 mt-2" style="height:48px;">
                        {% set maxDay = 1 %}
                        {% for day in newsLast7 %}
                            {% if day.count > maxDay %}{% set maxDay = day.count %}{% endif %}
                        {% endfor %}
                        {% for day in newsLast7 %}
                            <div class="bg-primary rounded-top flex-grow-1"
                                 style="height:{{ (day.count / maxDay * 100)|round }}%;min-height:4px;"
                                 title="{{ day.day }} : {{ day.count }} news"></div>
                        {% endfor %}
                    </div>
                    <div class="d-flex gap-1 mt-1">
                        {% for day in newsLast7 %}
                            <div class="flex-grow-1 text-center" style="font-size:10px;color:#9ca3af;">{{ day.day|date('d/m') }}</div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# ── Top news ── #}
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold">News les plus consultées</div>
                <div class="card-body p-0">
                    {% for news in topNews %}
                        <div class="d-flex align-items-start gap-2 p-3 border-bottom">
                            <span class="fw-bold text-secondary fs-5">{{ loop.index }}</span>
                            <div class="flex-grow-1 small">{{ news.content|striptags|slice(0,80) }}{% if news.content|length > 80 %}…{% endif %}</div>
                            <small class="text-muted text-nowrap">👁 {{ news.views }}</small>
                        </div>
                    {% else %}
                        <p class="text-muted p-3 small">Aucune news.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

    </div>

    {# ── Signalements ── #}
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">Derniers signalements communautaires</div>
        <div class="card-body p-0">
            {% if communityNews is not empty %}
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Contenu</th>
                            <th>Type</th>
                            <th>Auteur</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in communityNews %}
                            <tr>
                                <td class="small">{{ item.content|striptags|slice(0,80) }}…</td>
                                <td><span class="badge bg-warning text-dark">{{ item.type }}</span></td>
                                <td class="small text-muted">{{ item.author }}</td>
                                <td class="small text-muted text-nowrap">{{ item.published_at|date('d/m/Y H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted p-3 small">Aucun signalement.</p>
            {% endif %}
        </div>
    </div>

    {# ── Actions ── #}
    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('app_news') }}" class="btn btn-primary btn-sm">📰 Gérer les actualités</a>
        <a href="/api/admin/users" class="btn btn-secondary btn-sm">👥 Gérer les utilisateurs</a>
    </div>

</div>
{% endblock %}