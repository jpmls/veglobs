{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - VeGlobs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-page {
            font-family: 'Inter', system-ui, sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            padding: 28px 24px 60px;
            max-width: 1200px;
            margin: 0 auto;
            color: #111827;
        }

        .admin-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .admin-header h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #111827;
            margin: 0;
        }

        .admin-header p {
            font-size: 13px;
            color: #6b7280;
            margin: 4px 0 0;
        }

        .admin-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            color: #374151;
            text-decoration: none;
            transition: all .15s;
        }
        .admin-back:hover { background: #f9fafb; color: #111827; }

        /* ── Grille stats ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 14px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 18px 20px;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
            position: relative;
            overflow: hidden;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            border-radius: 14px 14px 0 0;
        }
        .stat-card.blue::before   { background: #0891b2; }
        .stat-card.green::before  { background: #16a34a; }
        .stat-card.purple::before { background: #7c3aed; }
        .stat-card.orange::before { background: #ea580c; }

        .stat-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        .stat-value {
            font-size: 32px;
            font-weight: 800;
            color: #111827;
            letter-spacing: -1px;
            line-height: 1;
        }
        .stat-sub {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 6px;
        }
        .stat-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            background: #f0fdf4;
            color: #16a34a;
            margin-top: 6px;
        }

        /* ── Section titre ── */
        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #111827;
            margin: 0 0 14px;
        }

        /* ── Grille contenu ── */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .panel {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 20px;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
        }

        /* ── Barres types ── */
        .type-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }
        .type-bar-label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            min-width: 100px;
            text-transform: capitalize;
        }
        .type-bar-track {
            flex: 1;
            height: 8px;
            background: #f3f4f6;
            border-radius: 4px;
            overflow: hidden;
        }
        .type-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width .5s;
        }
        .type-bar-count {
            font-size: 12px;
            color: #6b7280;
            min-width: 30px;
            text-align: right;
        }

        /* ── Top news ── */
        .news-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #f3f4f6;
        }
        .news-row:last-child { border-bottom: none; }
        .news-rank {
            font-size: 18px;
            font-weight: 800;
            color: #e5e7eb;
            min-width: 24px;
            text-align: center;
        }
        .news-row-title {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
            flex: 1;
            line-height: 1.4;
        }
        .news-row-views {
            font-size: 12px;
            color: #6b7280;
            white-space: nowrap;
        }

        /* ── Tableau signalements ── */
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .admin-table th {
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0 0 10px;
            border-bottom: 1px solid #f3f4f6;
        }
        .admin-table td {
            padding: 10px 0;
            border-bottom: 1px solid #f9fafb;
            color: #374151;
            vertical-align: top;
        }
        .admin-table tr:last-child td { border-bottom: none; }

        .badge-type {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
        }
        .badge-perturbation { background: #fef2f2; color: #dc2626; }
        .badge-travaux      { background: #fffbeb; color: #d97706; }
        .badge-info         { background: #eff6ff; color: #2563eb; }
        .badge-incident     { background: #fff7ed; color: #ea580c; }

        /* ── Sparkline 7 jours ── */
        .sparkline {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 48px;
            margin-top: 10px;
        }
        .spark-bar {
            flex: 1;
            background: #0891b2;
            border-radius: 3px 3px 0 0;
            min-height: 4px;
            transition: height .3s;
            position: relative;
        }
        .spark-bar:hover { background: #0e7490; }
        .spark-label {
            display: flex;
            gap: 4px;
            margin-top: 4px;
        }
        .spark-label span {
            flex: 1;
            font-size: 10px;
            color: #9ca3af;
            text-align: center;
        }

        @media (max-width: 700px) {
            .content-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="admin-page">

    {# ── Header ── #}
    <div class="admin-header">
        <div>
            <h1>🛠 Dashboard Admin</h1>
            <p>Bienvenue {{ app.user.email }} — Vue d'ensemble de VeGlobs</p>
        </div>
        <a href="{{ path('app_news') }}" class="admin-back">
            ← Retour au site
        </a>
    </div>

    {# ── Stats principales ── #}
    <div class="stats-grid">
        <div class="stat-card blue">
            <div class="stat-label">Actualités totales</div>
            <div class="stat-value">{{ totalNews }}</div>
            <div class="stat-badge">+{{ newsToday }} aujourd'hui</div>
        </div>
        <div class="stat-card green">
            <div class="stat-label">Utilisateurs</div>
            <div class="stat-value">{{ totalUsers }}</div>
            <div class="stat-sub">+{{ newUsers }} aujourd'hui</div>
        </div>
        <div class="stat-card purple">
            <div class="stat-label">Commentaires</div>
            <div class="stat-value">{{ totalComments }}</div>
            <div class="stat-sub">+{{ commentsToday }} aujourd'hui</div>
        </div>
        <div class="stat-card orange">
            <div class="stat-label">Signalements</div>
            <div class="stat-value">{{ communityNews|length }}</div>
            <div class="stat-sub">sources communautaires</div>
        </div>
    </div>

    {# ── Contenu principal ── #}
    <div class="content-grid">

        {# Types de news #}
        <div class="panel">
            <div class="section-title">Répartition par type</div>
            {% set maxCount = 1 %}
            {% for item in newsByType %}
                {% if item.count > maxCount %}{% set maxCount = item.count %}{% endif %}
            {% endfor %}
            {% for item in newsByType %}
                {% set colors = {
                    'perturbation': '#dc2626',
                    'travaux': '#d97706',
                    'info': '#0891b2',
                    'incident': '#ea580c'
                } %}
                <div class="type-bar">
                    <div class="type-bar-label">{{ item.type }}</div>
                    <div class="type-bar-track">
                        <div class="type-bar-fill" style="width:{{ (item.count / maxCount * 100)|round }}%;background:{{ colors[item.type]|default('#6b7280') }};"></div>
                    </div>
                    <div class="type-bar-count">{{ item.count }}</div>
                </div>
            {% endfor %}

            {# Activité 7 derniers jours #}
            <div class="section-title" style="margin-top:20px;">Activité — 7 derniers jours</div>
            {% set maxDay = 1 %}
            {% for day in newsLast7 %}
                {% if day.count > maxDay %}{% set maxDay = day.count %}{% endif %}
            {% endfor %}
            <div class="sparkline">
                {% for day in newsLast7 %}
                    <div class="spark-bar" style="height:{{ (day.count / maxDay * 100)|round }}%;" title="{{ day.day }} : {{ day.count }} news"></div>
                {% endfor %}
            </div>
            <div class="spark-label">
                {% for day in newsLast7 %}
                    <span>{{ day.day|date('d/m') }}</span>
                {% endfor %}
            </div>
        </div>

        {# News les plus consultées #}
        <div class="panel">
            <div class="section-title">News les plus consultées</div>
            {% for news in topNews %}
                <div class="news-row">
                    <div class="news-rank">{{ loop.index }}</div>
                    <div class="news-row-title">
                        {{ news.content|striptags|slice(0, 80) }}{% if news.content|length > 80 %}…{% endif %}
                    </div>
                    <div class="news-row-views">👁 {{ news.views }}</div>
                </div>
            {% else %}
                <p style="color:#9ca3af;font-size:13px;">Aucune news pour l'instant.</p>
            {% endfor %}
        </div>

    </div>

    {# ── Signalements communautaires ── #}
    <div class="panel">
        <div class="section-title">Derniers signalements communautaires</div>
        {% if communityNews is not empty %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Contenu</th>
                        <th>Type</th>
                        <th>Auteur</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in communityNews %}
                        <tr>
                            <td>{{ item.content|striptags|slice(0, 80) }}{% if item.content|length > 80 %}…{% endif %}</td>
                            <td>
                                <span class="badge-type badge-{{ item.type }}">{{ item.type }}</span>
                            </td>
                            <td style="color:#6b7280;">{{ item.author }}</td>
                            <td style="color:#9ca3af;white-space:nowrap;">{{ item.published_at|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p style="color:#9ca3af;font-size:13px;">Aucun signalement communautaire.</p>
        {% endif %}
    </div>

    {# ── Gestion rapide ── #}
    <div style="display:flex;gap:10px;margin-top:16px;flex-wrap:wrap;">
        <a href="{{ path('app_news') }}" style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:#0891b2;color:#fff;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;">
            📰 Gérer les actualités
        </a>
        <a href="/api/admin/users" style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:#7c3aed;color:#fff;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;">
            👥 Gérer les utilisateurs
        </a>
    </div>

</div>
{% endblock %}
