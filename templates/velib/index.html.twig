{% extends 'base.html.twig' %}

{% block title %}Carte Vélib - VeGlobs{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>
    <style>
        #map { height: 70vh; min-height: 500px; border-radius: 12px; }
    </style>
{% endblock %}

{% block body %}
<div class="container">
    <h1 class="h3 mb-1"><i class="bi bi-bicycle me-2"></i>Carte Vélib</h1>
    <p class="text-muted mb-4">Stations Vélib en temps réel.</p>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label fw-semibold small">Ville</label>
            <select id="cityFilter" class="form-select form-select-sm">
                <option value="ALL">Toutes les villes</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small">Arrondissement</label>
            <select id="arrFilter" class="form-select form-select-sm" disabled>
                <option value="ALL">Tous</option>
                {% for i in 1..20 %}
                    <option value="{{ i }}">{{ i }}e</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button id="resetBtn" class="btn btn-outline-dark btn-sm w-100">Réinitialiser</button>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge bg-danger" id="stationCount">0 stations</span>
                <span class="badge bg-success" id="bikeCount">0 vélos</span>
                <span class="badge bg-secondary" id="dockCount">0 places</span>
            </div>
        </div>
    </div>

    <div id="map" class="mb-3 shadow-sm"></div>

    <div class="d-flex gap-3">
        <small><span class="badge bg-danger">●</span> 0 vélo</small>
        <small><span class="badge bg-warning text-dark">●</span> 1-3 vélos</small>
        <small><span class="badge bg-success">●</span> 4+ vélos</small>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <script>
        const map = L.map('map').setView([48.8566, 2.3522], 11);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);

        const cityFilter = document.getElementById('cityFilter');
        const arrFilter  = document.getElementById('arrFilter');
        const resetBtn   = document.getElementById('resetBtn');

        let allStations = [];
        let clusterLayer = L.markerClusterGroup();
        map.addLayer(clusterLayer);

        function getColor(n) {
            if (!n) return '#ef4444';
            if (n <= 3) return '#f59e0b';
            return '#22c55e';
        }

        function render() {
            const city = cityFilter.value;
            const arr  = arrFilter.value;
            const stations = allStations.filter(s => {
                if (city !== 'ALL' && (s.city||'').trim() !== city) return false;
                if (city === 'Paris' && arr !== 'ALL' && Number(s.arrondissement) !== Number(arr)) return false;
                return true;
            });
            clusterLayer.clearLayers();
            stations.forEach(s => {
                if (!s.lat || !s.lon) return;
                const m = L.circleMarker([s.lat, s.lon], { radius:7, color:'#fff', fillColor: getColor(s.availableBikes), fillOpacity:0.95, weight:1 });
                m.bindPopup(`<b>${s.name||'Station'}</b><br>Vélos: ${s.availableBikes||0}<br>Places: ${s.availableStands||0}`);
                clusterLayer.addLayer(m);
            });
            document.getElementById('stationCount').textContent = stations.length + ' stations';
            document.getElementById('bikeCount').textContent = stations.reduce((a,s)=>a+(s.availableBikes||0),0) + ' vélos';
            document.getElementById('dockCount').textContent = stations.reduce((a,s)=>a+(s.availableStands||0),0) + ' places';
            arrFilter.disabled = city !== 'Paris';
            if (city !== 'Paris') arrFilter.value = 'ALL';
        }

        cityFilter.addEventListener('change', render);
        arrFilter.addEventListener('change', render);
        resetBtn.addEventListener('click', () => { cityFilter.value='ALL'; arrFilter.value='ALL'; render(); });

        fetch('/api/bikes/stations').then(r=>r.json()).then(result => {
            allStations = result.data || [];
            const cities = [...new Set(allStations.map(s=>(s.city||'').trim()).filter(Boolean))].sort();
            cities.forEach(c => cityFilter.appendChild(Object.assign(document.createElement('option'), {value:c, textContent:c})));
            render();
        }).catch(e => console.error(e));
    </script>
{% endblock %}
