{% extends 'base.html.twig' %}

{% block title %}Connexion - VeGlobs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-left">
        <div class="auth-content">
            <div class="auth-header">
                <a href="{{ path('app_news') }}" class="back-btn">
                    <i class="ri-arrow-left-line"></i>
                </a>
                <a href="{{ path('app_register') }}" class="register-link">Créer un compte</a>
            </div>

            <div class="form-content">
                <h1 class="form-title">Connexion</h1>
                <p class="form-subtitle">
                    Bienvenue sur VeGlobs. Connecte-toi pour accéder à ton espace utilisateur.
                </p>

                {% if error is defined and error %}
                    <div class="auth-alert auth-alert-error">
                        Email ou mot de passe incorrect.
                    </div>
                {% endif %}

                {% for message in app.flashes('success') %}
                    <div class="auth-alert auth-alert-success">
                        {{ message }}
                    </div>
                {% endfor %}

                <form method="post">
                    <input
                        type="email"
                        name="_username"
                        value="{{ last_username|default('') }}"
                        class="auth-input"
                        placeholder="Adresse email"
                        autocomplete="email"
                        required
                        autofocus
                    >

                    <input
                        type="password"
                        name="_password"
                        class="auth-input"
                        placeholder="Mot de passe"
                        autocomplete="current-password"
                        required
                    >

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="submit-btn" type="submit">Se connecter</button>
                </form>

                <span class="bottom-line"></span>

                <p class="auth-footer-text">
                    Pas de compte ?
                    <a href="{{ path('app_register') }}">Créer un compte</a>
                </p>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-overlay"></div>
        <div class="auth-image-text">
            <h3>VeGlobs sur Paris</h3>
            <p>
                Suivez les perturbations, travaux, retards et informations utiles
                des transports parisiens en temps réel.
            </p>
        </div>
    </div>
</div>
{% endblock %}