{% extends 'base.html.twig' %}

{% block title %}Mes lignes suivies - VeGlobs{% endblock %}

{% block body %}
<div class="container">

    <h1 class="h3 mb-1">Mes lignes suivies</h1>
    <p class="text-muted mb-4">Suivez vos lignes favorites pour recevoir leurs actualités en priorité.</p>

    {% if not app.user %}
        <div class="alert alert-danger text-center">
            <p class="fw-semibold mb-2">Connectez-vous pour suivre des lignes.</p>
            <a href="{{ path('app_login') }}" class="btn btn-primary btn-sm">Se connecter</a>
        </div>
    {% else %}

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">Choisissez vos lignes</div>
        <div class="card-body">

            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-2">Métro</div>
                <div class="d-flex flex-wrap gap-2">
                    {% set metroLines = [
                        {n:'1',c:'ffbe00',t:'1a1a1a'},{n:'2',c:'003ca6',t:'fff'},{n:'3',c:'837902',t:'fff'},
                        {n:'3b',c:'6ec4e8',t:'1a1a1a'},{n:'4',c:'be418d',t:'fff'},{n:'5',c:'ff7e2e',t:'fff'},
                        {n:'6',c:'6eca97',t:'1a1a1a'},{n:'7',c:'fa9aba',t:'1a1a1a'},{n:'7b',c:'6eca97',t:'1a1a1a'},
                        {n:'8',c:'e19bdf',t:'1a1a1a'},{n:'9',c:'b6bd00',t:'1a1a1a'},{n:'10',c:'c9910d',t:'fff'},
                        {n:'11',c:'704b1c',t:'fff'},{n:'12',c:'007852',t:'fff'},{n:'13',c:'6ec4e8',t:'1a1a1a'},
                        {n:'14',c:'62259d',t:'fff'}
                    ] %}
                    {% for line in metroLines %}
                        <button class="line-btn btn rounded-circle fw-bold p-0"
                            style="width:36px;height:36px;font-size:11px;background:#{{ line.c }};color:#{{ line.t }};border:2px solid transparent;"
                            data-network="metro" data-line="{{ line.n }}" title="Métro {{ line.n }}">{{ line.n }}</button>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-2">RER</div>
                <div class="d-flex flex-wrap gap-2">
                    {% set rerLines = [
                        {n:'A',c:'d1302f',t:'fff'},{n:'B',c:'427dbd',t:'fff'},{n:'C',c:'fcd946',t:'1a1a1a'},
                        {n:'D',c:'5e9620',t:'fff'},{n:'E',c:'bd76a1',t:'fff'}
                    ] %}
                    {% for line in rerLines %}
                        <button class="line-btn btn fw-bold p-0"
                            style="width:36px;height:36px;font-size:11px;border-radius:8px;background:#{{ line.c }};color:#{{ line.t }};border:2px solid transparent;"
                            data-network="rer" data-line="{{ line.n }}" title="RER {{ line.n }}">{{ line.n }}</button>
                    {% endfor %}
                </div>
            </div>

            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-2">Tram</div>
                <div class="d-flex flex-wrap gap-2">
                    {% for line in ['T1','T2','T3a','T3b','T4','T5','T6','T7','T8','T9','T10','T11','T12','T13'] %}
                        <button class="line-btn btn fw-bold px-2"
                            style="height:32px;font-size:10px;border-radius:8px;background:#f59e0b;color:#1a1a1a;border:2px solid transparent;"
                            data-network="tram" data-line="{{ line }}" title="Tram {{ line }}">{{ line }}</button>
                    {% endfor %}
                </div>
            </div>

            <div>
                <div class="text-muted small fw-semibold text-uppercase mb-2">Bus / Transilien</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="line-btn btn fw-bold px-3"
                        style="height:32px;font-size:12px;border-radius:8px;background:#2563eb;color:#fff;border:2px solid transparent;"
                        data-network="bus" data-line="">Tous les bus</button>
                    <button class="line-btn btn fw-bold px-3"
                        style="height:32px;font-size:12px;border-radius:8px;background:#7c3aed;color:#fff;border:2px solid transparent;"
                        data-network="rail" data-line="">Transilien</button>
                </div>
            </div>

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">📰 Actualités de vos lignes</div>
        <div class="card-body" id="follow-news-list">
            <div class="text-center text-muted py-4">
                <div class="fs-1"></div>
                <p>Suivez des lignes pour voir leurs actualités ici.</p>
            </div>
        </div>
    </div>

    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    if (!document.querySelector('.line-btn')) return;

    async function loadFollowed() {
        try {
            const res  = await fetch('/api/follow');
            const data = await res.json();
            data.forEach(f => {
                const btn = document.querySelector(`.line-btn[data-network="${f.network}"][data-line="${f.line}"]`);
                if (btn) btn.style.borderColor = '#111827';
            });
            loadNews();
        } catch(e) { console.error(e); }
    }

    document.querySelectorAll('.line-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const followed = btn.style.borderColor === 'rgb(17, 24, 39)';
            await fetch('/api/follow', {
                method: followed ? 'DELETE' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ network: btn.dataset.network, line: btn.dataset.line })
            });
            btn.style.borderColor = followed ? 'transparent' : '#111827';
            loadNews();
        });
    });

    async function loadNews() {
        const list = document.getElementById('follow-news-list');
        list.innerHTML = '<div class="text-center text-muted py-3">Chargement…</div>';
        try {
            const res  = await fetch('/api/follow/news');
            const data = await res.json();
            if (!data.data?.length) {
                list.innerHTML = '<div class="text-center text-muted py-4"><div class="fs-1">⭐</div><p>Suivez des lignes pour voir leurs actualités ici.</p></div>';
                return;
            }
            list.innerHTML = data.data.map(news => {
                const date = new Date(news.published_at).toLocaleDateString('fr-FR', {day:'numeric',month:'short'});
                return `<div class="border-bottom pb-3 mb-3">
                    <div class="d-flex gap-2 mb-1">
                        <span class="badge bg-warning text-dark">${news.type}</span>
                        <span class="badge bg-secondary">${news.network}${news.line ? ' · ' + news.line : ''}</span>
                    </div>
                    <p class="small mb-1">${(news.content||'').slice(0,150)}…</p>
                    <small class="text-muted">📅 ${date}</small>
                </div>`;
            }).join('');
        } catch(e) {
            list.innerHTML = '<p class="text-danger small">Erreur de chargement.</p>';
        }
    }

    loadFollowed();
})();
</script>
{% endblock %}
