{% extends 'base.html.twig' %}

{% block title %}Planificateur de trajet{% endblock %}

{% block body %}
<div class="container my-4">
    <h1>Planificateur de trajet</h1>

    <!-- Formulaire de recherche pour départ et destination -->
    <div class="planner-form">
        <div class="form-group">
            <label for="startInput">Départ</label>
            <input type="text" id="startInput" class="form-control" placeholder="Départ" autocomplete="off">
            <div id="startResults" class="results"></div>
        </div>

        <div class="form-group mt-3">
            <label for="endInput">Destination</label>
            <input type="text" id="endInput" class="form-control" placeholder="Destination" autocomplete="off">
            <div id="endResults" class="results"></div>
        </div>
    </div>

    <!-- Affichage du résumé du trajet -->
    <div id="resultBox" class="mt-3">
        Sélectionne un départ et une destination
    </div>

    <!-- Affichage de la carte Leaflet -->
    <div id="map" style="height: 600px; margin-top: 20px;"></div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<!-- Ajout du CSS pour la carte Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">

<style>
    #map {
        height: 600px;
        margin-top: 20px;
        border-radius: 12px;
    }

    .results {
        background: white;
        border: 1px solid #ccc;
        display: none;
        position: absolute;
        z-index: 1000;
        width: 100%;
        max-height: 150px;
        overflow-y: auto;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
    }

    .results div {
        padding: 8px;
        cursor: pointer;
    }

    .results div:hover {
        background: #f1f1f1;
    }
</style>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<!-- Ajout de la bibliothèque Leaflet et du script de gestion de la carte -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<!-- Ajout de la bibliothèque proj4.js pour la conversion des coordonnées EPSG:2154 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.9.2/proj4.js"></script>
<script src="{{ asset('js/route-planner.js') }}"></script>
{% endblock %}