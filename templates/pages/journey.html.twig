{% extends 'base.html.twig' %}

{% block title %}Itinéraire - VeGlobs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css" />
    <style>
        #map { height: calc(100vh - 72px); min-height: 600px; }
        .journey-col { position: sticky; top: 72px; max-height: calc(100vh - 90px); overflow-y: auto; }
        .line-results { position:absolute; top:100%; left:0; right:0; background:#fff; border:1px solid #dee2e6; border-radius:8px; z-index:1000; display:none; max-height:200px; overflow-y:auto; }
        .line-results.visible { display:block; }
        .line-result-item { padding:8px 12px; cursor:pointer; font-size:13px; border-bottom:1px solid #f8f9fa; }
        .line-result-item:hover { background:#f8f9fa; }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid px-3">
    <div class="row g-3">

        {# ── Panneau gauche ── #}
        <div class="col-lg-4 journey-col">

            <h1 class="h4 mb-1 mt-2">🗺 Itinéraire</h1>
            <p class="text-muted small mb-3">Calculez votre trajet en transports en commun.</p>

            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="mb-3 position-relative">
                        <label class="form-label small fw-semibold">
                            <span style="color:#16a34a">●</span> Départ
                        </label>
                        <input type="text" id="fromInput" class="form-control form-control-sm" placeholder="Ex : Châtelet, Gare de Lyon..." autocomplete="off">
                        <div id="fromResults" class="line-results"></div>
                        <input type="hidden" id="fromId">
                    </div>

                    <div class="text-end mb-3">
                        <button id="swapBtn" type="button" class="btn btn-outline-secondary btn-sm">⇅ Inverser</button>
                    </div>

                    <div class="mb-3 position-relative">
                        <label class="form-label small fw-semibold">
                            <span style="color:#dc2626">●</span> Arrivée
                        </label>
                        <input type="text" id="toInput" class="form-control form-control-sm" placeholder="Ex : Nation, La Défense..." autocomplete="off">
                        <div id="toResults" class="line-results"></div>
                        <input type="hidden" id="toId">
                    </div>

                    <button id="computeBtn" type="button" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>Calculer l'itinéraire
                    </button>
                </div>
            </div>

            <div id="journeyResults" style="display:none;" class="mb-3"></div>

            <hr>

            <p class="small fw-semibold mb-2">Afficher les arrêts sur la carte</p>
            <div class="d-flex flex-wrap gap-2 mb-3">
                {% for type, color in {metro:'#003ca6', rer:'#d1302f', tram:'#f59e0b', bus:'#2563eb', rail:'#7c3aed'} %}
                    <button type="button" class="type-filter btn btn-outline-secondary btn-sm d-flex align-items-center gap-1" data-type="{{ type }}">
                        <span style="width:10px;height:10px;border-radius:50%;background:{{ color }};display:inline-block;flex-shrink:0;"></span>
                        {{ type|capitalize }}
                    </button>
                {% endfor %}
            </div>

            <div class="mb-3 position-relative">
                <label class="form-label small fw-semibold">Rechercher un arrêt</label>
                <input type="text" id="stopSearch" class="form-control form-control-sm" placeholder="Ex : Châtelet, Nation...">
                <div id="stopResults" class="line-results"></div>
            </div>

            <div id="stopInfo" class="alert alert-light border small">
                <strong>Aucun arrêt sélectionné</strong><br>
                Clique sur un filtre ou recherche un arrêt.
            </div>

            <h2 id="lineTitle" style="display:none;"></h2>
        </div>

        {# ── Carte ── #}
        <div class="col-lg-8 p-0">
            <div id="map" class="rounded shadow-sm"></div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.9.0/proj4.js"></script>
    <script src="{{ asset('js/line-map.js') }}"></script>
    <script src="{{ asset('js/journey-planner.js') }}"></script>
{% endblock %}