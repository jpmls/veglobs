{% extends 'base.html.twig' %}

{% block title %}Carte Vélib - VeGlobs{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>
    <style>#map { height: 70vh; min-height: 500px; border-radius: 12px; }</style>
{% endblock %}

{% block body %}
<div class="container">
    <h1 class="h3 mb-1"><i class="bi bi-bicycle me-2"></i>Carte Vélib</h1>
    <p class="text-muted mb-3">Stations Vélib en temps réel. Filtrez par ville ou arrondissement.</p>

    <div class="row g-2 mb-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Ville</label>
            <select id="cityFilter" class="form-select form-select-sm"></select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Arrondissement (Paris)</label>
            <select id="arrFilter" class="form-select form-select-sm" disabled>
                <option value="ALL">Tous</option>
                {% for i in 1..20 %}<option value="{{ i }}">{{ i }}e</option>{% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <button id="resetBtn" class="btn btn-outline-dark btn-sm w-100">Réinitialiser</button>
        </div>
        <div class="col-md-4 d-flex gap-2 flex-wrap">
            <span class="badge bg-secondary" id="stationCount">0 stations</span>
            <span class="badge bg-success" id="bikeCount">0 vélos</span>
            <span class="badge bg-primary" id="dockCount">0 places</span>
        </div>
    </div>

    <div id="map" class="shadow-sm mb-3"></div>

    <div class="d-flex gap-3 small">
        <span><span style="color:#ef4444">●</span> 0 vélo</span>
        <span><span style="color:#f59e0b">●</span> 1-3 vélos</span>
        <span><span style="color:#22c55e">●</span> 4+ vélos</span>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script>
const map = L.map('map').setView([48.8566, 2.3522], 11);
L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {attribution:'© OpenStreetMap'}).addTo(map);

const cityFilter = document.getElementById('cityFilter');
const arrFilter  = document.getElementById('arrFilter');
let allStations  = [], cluster = L.markerClusterGroup();
map.addLayer(cluster);

function color(n) { return !n ? '#ef4444' : n <= 3 ? '#f59e0b' : '#22c55e'; }

function render() {
    const city = cityFilter.value, arr = arrFilter.value;
    const list = allStations.filter(s => {
        if (city !== 'ALL' && (s.city||'').trim() !== city) return false;
        if (city === 'Paris' && arr !== 'ALL' && Number(s.arrondissement) !== Number(arr)) return false;
        return true;
    });
    cluster.clearLayers();
    list.forEach(s => {
        if (!s.lat || !s.lon) return;
        L.circleMarker([s.lat, s.lon], {radius:7, color:'#fff', fillColor:color(s.availableBikes), fillOpacity:.95, weight:1})
         .bindPopup(`<b>${s.name||'Station'}</b><br>Vélos: ${s.availableBikes||0}<br>Places: ${s.availableStands||0}`)
         .addTo(cluster);
    });
    document.getElementById('stationCount').textContent = list.length + ' stations';
    document.getElementById('bikeCount').textContent    = list.reduce((a,s)=>a+(s.availableBikes||0),0) + ' vélos';
    document.getElementById('dockCount').textContent    = list.reduce((a,s)=>a+(s.availableStands||0),0) + ' places';
    arrFilter.disabled = city !== 'Paris';
    if (city !== 'Paris') arrFilter.value = 'ALL';
}

cityFilter.addEventListener('change', render);
arrFilter.addEventListener('change', render);
document.getElementById('resetBtn').addEventListener('click', () => { cityFilter.value='ALL'; arrFilter.value='ALL'; render(); });

fetch('/api/bikes/stations').then(r=>r.json()).then(result => {
    allStations = result.data || [];
    cityFilter.innerHTML = '<option value="ALL">Toutes les villes</option>';
    [...new Set(allStations.map(s=>(s.city||'').trim()).filter(Boolean))].sort()
        .forEach(c => cityFilter.add(new Option(c, c)));
    render();
}).catch(console.error);
</script>
{% endblock %}