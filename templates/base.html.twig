<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% block title %}VeGlobs sur Paris{% endblock %}</title>

  {# ── SEO Métadonnées ── #}
  <meta name="description" content="{% block meta_description %}VeGlobs — Plateforme d'information trafic pour les transports parisiens. Perturbations, travaux, actualités en temps réel.{% endblock %}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ app.request.uri }}">

  {# Open Graph #}
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="VeGlobs sur Paris">
  <meta property="og:title"       content="{% block og_title %}VeGlobs sur Paris{% endblock %}">
  <meta property="og:description" content="{% block og_description %}Plateforme d'information trafic parisienne.{% endblock %}">
  <meta property="og:url"         content="{{ app.request.uri }}">

  {# Twitter Card #}
  <meta name="twitter:card"        content="summary">
  <meta name="twitter:title"       content="{% block twitter_title %}VeGlobs sur Paris{% endblock %}">
  <meta name="twitter:description" content="{% block twitter_description %}Perturbations et actualités transports Paris.{% endblock %}">

  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.14.0/css/all.css" crossorigin="anonymous">
  <link href="https://cdn.lineicons.com/2.0/LineIcons.css" rel="stylesheet">

  <link rel="shortcut icon" href="/images/ratp.png" type="image/png">
  <link rel="stylesheet" href="/css/style.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  {% block stylesheets %}{% endblock %}
</head>

<body id="top">
  {% block body %}{% endblock %}

  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

  {% block javascripts %}{% endblock %}
</body>
</html>
