<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% block title %}VeGlobs sur Paris{% endblock %}</title>

  {# ── SEO ── #}
  <meta name="description" content="{% block meta_description %}VeGlobs — Plateforme d'information trafic pour les transports parisiens.{% endblock %}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ app.request.uri }}">
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="VeGlobs sur Paris">
  <meta property="og:title"       content="{% block og_title %}VeGlobs sur Paris{% endblock %}">
  <meta property="og:description" content="{% block og_description %}Plateforme d'information trafic parisienne.{% endblock %}">
  <meta property="og:url"         content="{{ app.request.uri }}">
  <meta name="twitter:card"        content="summary">
  <meta name="twitter:title"       content="{% block twitter_title %}VeGlobs sur Paris{% endblock %}">
  <meta name="twitter:description" content="{% block twitter_description %}Perturbations et actualités transports Paris.{% endblock %}">

  {# ── Bootstrap 5 ── #}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <link rel="shortcut icon" href="/images/ratp.png" type="image/png">

  {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light">

  {# ── NAVBAR ── #}
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold fs-5" href="{{ path('app_home') }}">
        🚇 VeGlobs
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link {% if app.request.pathinfo starts with '/news' %}active{% endif %}" href="{{ path('app_news') }}">
              <i class="bi bi-newspaper me-1"></i>Actualités
            </a>
          </li>
          {% if app.user %}
          <li class="nav-item">
            <a class="nav-link {% if app.request.pathinfo == '/mes-lignes' %}active{% endif %}" href="{{ path('app_follow') }}">
              <i class="bi bi-star me-1"></i>Mes lignes
            </a>
          </li>
          {% endif %}
          {% if is_granted('ROLE_ADMIN') %}
          <li class="nav-item">
            <a class="nav-link {% if app.request.pathinfo starts with '/admin' %}active{% endif %}" href="{{ path('app_admin') }}">
              <i class="bi bi-speedometer2 me-1"></i>Admin
            </a>
          </li>
          {% endif %}
        </ul>
        <ul class="navbar-nav ms-auto">
          {% if app.user %}
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i>
                {{ app.user.firstName|default(app.user.email) }}
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="{{ path('app_follow') }}"><i class="bi bi-star me-2"></i>Mes lignes</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
              </ul>
            </li>
          {% else %}
            <li class="nav-item">
              <a class="nav-link" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right me-1"></i>Connexion</a>
            </li>
            <li class="nav-item">
              <a class="btn btn-primary btn-sm ms-2 my-1" href="{{ path('app_register') }}">S'inscrire</a>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>

  {# ── Flash messages ── #}
  {% for type, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mb-0 rounded-0" role="alert">
        <div class="container">{{ message }}</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endfor %}
  {% endfor %}

  {# ── Contenu ── #}
  <main class="py-4">
    {% block body %}{% endblock %}
  </main>

  {# ── Footer ── #}
  <footer class="bg-dark text-white py-4 mt-5">
    <div class="container">
      <div class="row">
        <div class="col-md-4 mb-3">
          <h5 class="fw-bold">🚇 VeGlobs</h5>
          <p class="text-muted small">Plateforme d'information trafic parisienne en temps réel.</p>
        </div>
        <div class="col-md-4 mb-3">
          <h6 class="fw-bold">Navigation</h6>
          <ul class="list-unstyled small">
            <li><a href="{{ path('app_news') }}" class="text-muted text-decoration-none">Actualités</a></li>
            {% if app.user %}
            <li><a href="{{ path('app_follow') }}" class="text-muted text-decoration-none">Mes lignes</a></li>
            {% endif %}
          </ul>
        </div>
        <div class="col-md-4 mb-3">
          <h6 class="fw-bold">Compte</h6>
          <ul class="list-unstyled small">
            {% if app.user %}
              <li><a href="{{ path('app_logout') }}" class="text-muted text-decoration-none">Déconnexion</a></li>
            {% else %}
              <li><a href="{{ path('app_login') }}" class="text-muted text-decoration-none">Connexion</a></li>
              <li><a href="{{ path('app_register') }}" class="text-muted text-decoration-none">Inscription</a></li>
            {% endif %}
          </ul>
        </div>
      </div>
      <hr class="border-secondary">
      <p class="text-muted text-center small mb-0">© {{ "now"|date("Y") }} VeGlobs sur Paris</p>
    </div>
  </footer>

  {# ── Bootstrap JS ── #}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  {% block javascripts %}{% endblock %}
</body>
</html>
